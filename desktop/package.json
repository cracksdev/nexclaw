{
  "name": "nexclaw-desktop",
  "version": "0.1.0",
  "description": "NexClaw — desktop GUI for the NexClaw CLI",
  "author": "NexClaw Contributors",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "package:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:all": "electron-builder --win --mac",
    "package:unsigned": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "lucide-react": "^0.500.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/diff": "^7.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@vitejs/plugin-react": "^4.4.0",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
